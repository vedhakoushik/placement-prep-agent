# ─────────────────────────────────────────────────────────────
#  .env.example — copy to .env and fill in your keys
#
#  cp .env.example .env
#  then edit .env (never commit .env to git)
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Google Gemini — free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Tavily web search — free at https://tavily.com
TAVILY_API_KEY=your_tavily_key_here

# ── Optional ──────────────────────────────────────────────────
# LangSmith tracing — free at https://smith.langchain.com
# LANGSMITH_API_KEY=your_langsmith_key_here
# LANGCHAIN_PROJECT=placement-prep-agent
# LANGCHAIN_TRACING_V2=true

# ── Docker only (set automatically by docker-compose.yml) ──────
# Do NOT set these when running locally — src/chroma_client.py
# falls back to PersistentClient when CHROMA_HOST is absent.
# CHROMA_HOST=chromadb
# CHROMA_PORT=8000
